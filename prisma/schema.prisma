generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  email                String?            @unique
  phone                String?            @unique
  passwordHash         String?
  firstName            String?
  lastName             String?
  displayName          String
  avatar               String?
  bio                  String?
  dateOfBirth          DateTime?
  gender               Gender?
  nationality          String?
  country              String?
  city                 String?
  address              String?
  status               UserStatus         @default("PENDING")
  role                 Role               @default("USER")
  emailVerified        DateTime?
  phoneVerified        DateTime?
  membershipLevel      MembershipLevel    @default("BRONZE")
  loyaltyPoints        Int                @default(0)
  language             String             @default("ar")
  preferredCurrency    String             @default("SYP")
  notificationSettings String?
  lastLogin            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  bookingsAsHost       Booking[]          @relation("HostBookings")
  bookingsAsGuest      Booking[]          @relation("GuestBookings")
  cart                 Cart?
  ownedCompanies       Company[]          @relation("CompanyOwner")
  employeeOf           CompanyEmployee[]
  oauthAccounts        OAuthAccount[]
  orders               Order[]
  products             Product[]
  replies              Reply[]
  reviewHelpful        ReviewHelpful[]
  reviewerProfile      ReviewerProfile?
  reviews              Review[]
  services             Service[]
  sessions             Session[]
  topics               Topic[]
  verifications        UserVerification[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
  @@map("users")
}

model OAuthAccount {
  id           String        @id @default(cuid())
  userId       String
  provider     OAuthProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model OTPCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      OTPType
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([phone, code, type])
  @@index([phone])
  @@map("otp_codes")
}

model UserVerification {
  id              String             @id @default(cuid())
  userId          String
  type            VerificationType
  status          VerificationStatus @default("PENDING")
  documentType    String?
  documentUrl     String?
  documentNumber  String?
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("user_verifications")
}

model Company {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  type            CompanyType
  description     String?
  email           String?
  phone           String?
  website         String?
  country         String?
  city            String?
  address         String?
  logo            String?
  coverImage      String?
  commercialReg   String?
  taxNumber       String?
  documents       String?
  status          CompanyStatus       @default("PENDING")
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  totalServices   Int                 @default(0)
  totalProducts   Int                 @default(0)
  totalBookings   Int                 @default(0)
  rating          Float               @default(0)
  reviewCount     Int                 @default(0)
  ownerId         String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  owner           User                @relation("CompanyOwner", fields: [ownerId], references: [id])
  employees       CompanyEmployee[]
  invitations     CompanyInvitation[]
  products        Product[]
  services        Service[]

  @@index([type])
  @@index([status])
  @@index([ownerId])
  @@map("companies")
}

model CompanyEmployee {
  id          String       @id @default(cuid())
  companyId   String
  userId      String
  role        EmployeeRole @default("STAFF")
  permissions String?
  invitedBy   String?
  joinedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@map("company_employees")
}

model CompanyInvitation {
  id        String           @id @default(cuid())
  companyId String
  email     String
  role      EmployeeRole     @default("STAFF")
  token     String           @unique
  status    InvitationStatus @default("PENDING")
  invitedBy String
  expiresAt DateTime
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@index([token])
  @@map("company_invitations")
}

model Destination {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  type             DestinationType
  description      String
  shortDesc        String?
  country          String            @default("سوريا")
  city             String
  address          String?
  latitude         Float?
  longitude        Float?
  images           String
  coverImage       String?
  highlights       String?
  bestTimeToVisit  String?
  entryFee         Float?            @default(0)
  openingHours     String?
  duration         String?
  rating           Float             @default(0)
  reviewCount      Int               @default(0)
  viewCount        Int               @default(0)
  visitCount       Int               @default(0)
  isVerified       Boolean           @default(false)
  verifiedAt       DateTime?
  verifiedBy       String?
  ownerId          String?
  companyId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  activities       Activity[]
  tourDestinations TourDestination[]

  @@index([type])
  @@index([city])
  @@index([isVerified])
  @@map("destinations")
}

model Activity {
  id                 String                 @id @default(cuid())
  title              String
  slug               String                 @unique
  type               ActivityType
  description        String
  shortDesc          String?
  destinationId      String?
  location           String
  meetingPoint       String?
  latitude           Float?
  longitude          Float?
  duration           Int
  maxParticipants    Int                    @default(10)
  minParticipants    Int                    @default(1)
  difficultyLevel    String?
  ageRestriction     String?
  price              Float
  currency           String                 @default("SYP")
  pricePerPerson     Boolean                @default(true)
  discountPrice      Float?
  images             String
  coverImage         String?
  videoUrl           String?
  included           String?
  excluded           String?
  requirements       String?
  availability       String?
  cancellationPolicy String?
  rating             Float                  @default(0)
  reviewCount        Int                    @default(0)
  bookingCount       Int                    @default(0)
  status             CompanyStatus          @default("PENDING")
  isFeatured         Boolean                @default(false)
  ownerId            String?
  companyId          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  destination        Destination?           @relation(fields: [destinationId], references: [id])
  availabilitySlots  ActivityAvailability[]
  tourActivities     TourActivity[]

  @@index([type])
  @@index([destinationId])
  @@index([status])
  @@index([isFeatured])
  @@map("activities")
}

model ActivityAvailability {
  id          String   @id @default(cuid())
  activityId  String
  date        DateTime
  startTime   String
  endTime     String
  maxCapacity Int
  bookedCount Int      @default(0)
  isAvailable Boolean  @default(true)
  price       Float?
  createdAt   DateTime @default(now())
  activity    Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, date, startTime])
  @@index([activityId])
  @@index([date])
  @@map("activity_availability")
}

model Tour {
  id                 String             @id @default(cuid())
  title              String
  slug               String             @unique
  type               TourType
  description        String
  shortDesc          String?
  durationDays       Int
  durationNights     Int
  maxParticipants    Int                @default(15)
  minParticipants    Int                @default(2)
  pricePerPerson     Float
  currency           String             @default("SYP")
  singleSupplement   Float?
  images             String
  coverImage         String?
  included           String?
  excluded           String?
  departureDates     String?
  cancellationPolicy String?
  rating             Float              @default(0)
  reviewCount        Int                @default(0)
  bookingCount       Int                @default(0)
  status             CompanyStatus      @default("PENDING")
  isFeatured         Boolean            @default(false)
  ownerId            String?
  companyId          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tourActivities     TourActivity[]
  availability       TourAvailability[]
  dailyProgram       TourDay[]
  destinations       TourDestination[]

  @@index([type])
  @@index([status])
  @@index([isFeatured])
  @@map("tours")
}

model TourDestination {
  id            String      @id @default(cuid())
  tourId        String
  destinationId String
  dayNumber     Int
  duration      Int?
  notes         String?
  destination   Destination @relation(fields: [destinationId], references: [id])
  tour          Tour        @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber, destinationId])
  @@index([tourId])
  @@index([destinationId])
  @@map("tour_destinations")
}

model TourDay {
  id            String  @id @default(cuid())
  tourId        String
  dayNumber     Int
  title         String
  description   String
  activities    String?
  meals         String?
  accommodation String?
  notes         String?
  tour          Tour    @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, dayNumber])
  @@index([tourId])
  @@map("tour_days")
}

model TourActivity {
  id         String   @id @default(cuid())
  tourId     String
  activityId String
  dayNumber  Int
  startTime  String?
  duration   Int?
  notes      String?
  activity   Activity @relation(fields: [activityId], references: [id])
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@index([activityId])
  @@map("tour_activities")
}

model TourAvailability {
  id          String   @id @default(cuid())
  tourId      String
  startDate   DateTime
  endDate     DateTime
  maxCapacity Int
  bookedCount Int      @default(0)
  isAvailable Boolean  @default(true)
  price       Float?
  createdAt   DateTime @default(now())
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
  @@index([startDate])
  @@map("tour_availability")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  location    String
  rating      Float       @default(0)
  reviews     Int         @default(0)
  image       String
  vendorId    String
  vendorName  String?
  companyId   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
  company     Company?    @relation(fields: [companyId], references: [id])
  vendor      User        @relation(fields: [vendorId], references: [id])

  @@index([companyId])
  @@map("products")
}

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  items  CartItem[]
  user   User       @relation(fields: [userId], references: [id])

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  product   Product @relation(fields: [productId], references: [id])
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Topic {
  id            String    @id @default(cuid())
  title         String
  content       String
  authorId      String
  categoryId    String
  subCategoryId String?
  likesCount    Int       @default(0)
  repliesCount  Int       @default(0)
  isOfficial    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime?
  replies       Reply[]
  author        User      @relation(fields: [authorId], references: [id])

  @@map("topics")
}

model Reply {
  id         String    @id @default(cuid())
  topicId    String
  content    String
  authorId   String
  likesCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?
  author     User      @relation(fields: [authorId], references: [id])
  topic      Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("replies")
}

model Booking {
  id         String        @id @default(cuid())
  guestId    String
  hostId     String
  serviceId  String
  checkIn    DateTime
  checkOut   DateTime
  guests     Int           @default(1)
  totalPrice Float
  status     BookingStatus @default("PENDING")
  escrowId   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  service    Service       @relation(fields: [serviceId], references: [id])
  host       User          @relation("HostBookings", fields: [hostId], references: [id])
  guest      User          @relation("GuestBookings", fields: [guestId], references: [id])

  @@map("bookings")
}

model Service {
  id               String    @id @default(cuid())
  title            String
  description      String
  location         String
  price            Float
  originalPrice    Float?
  rating           Float     @default(0)
  reviews          Int       @default(0)
  views            Int       @default(0)
  images           String
  type             String
  amenities        String
  features         String
  mainCategoryId   String
  subCategoryId    String?
  subSubCategoryId String?
  hostId           String?
  hostName         String?
  hostAvatar       String?
  isSuperhost      Boolean   @default(false)
  companyId        String?
  maxGuests        Int       @default(4)
  bedrooms         Int       @default(1)
  beds             Int       @default(1)
  baths            Int       @default(1)
  isPopular        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  bookings         Booking[]
  company          Company?  @relation(fields: [companyId], references: [id])
  host             User?     @relation(fields: [hostId], references: [id])

  @@index([companyId])
  @@index([mainCategoryId])
  @@index([isPopular])
  @@map("services")
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Float
  status    OrderStatus @default("PENDING")
  escrowId  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
  user      User        @relation(fields: [userId], references: [id])

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Escrow {
  id            String              @id @default(cuid())
  buyerId       String
  providerId    String
  amount        Float
  platformFee   Float               @default(0)
  netAmount     Float
  currency      String              @default("SYP")
  status        EscrowStatus        @default("PENDING")
  referenceType String
  referenceId   String
  fundedAt      DateTime?
  releasedAt    DateTime?
  refundedAt    DateTime?
  autoReleaseAt DateTime?
  notes         String?
  releaseNotes  String?
  refundReason  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  disputes      Dispute[]
  transactions  EscrowTransaction[]

  @@index([buyerId])
  @@index([providerId])
  @@index([status])
  @@index([referenceType, referenceId])
  @@map("escrows")
}

model EscrowTransaction {
  id          String                @id @default(cuid())
  escrowId    String
  type        EscrowTransactionType
  amount      Float
  currency    String                @default("SYP")
  description String?
  metadata    String?
  fromUserId  String?
  toUserId    String?
  createdAt   DateTime              @default(now())
  escrow      Escrow                @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([type])
  @@map("escrow_transactions")
}

model Dispute {
  id             String            @id @default(cuid())
  escrowId       String
  referenceType  String
  referenceId    String
  openedBy       String
  againstUser    String
  type           DisputeType
  reason         String
  description    String
  status         DisputeStatus     @default("OPEN")
  decision       DisputeDecision?
  decisionReason String?
  decidedBy      String?
  decidedAt      DateTime?
  escalatedAt    DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  messages       DisputeMessage[]
  timeline       DisputeTimeline[]
  escrow         Escrow            @relation(fields: [escrowId], references: [id])

  @@index([escrowId])
  @@index([openedBy])
  @@index([againstUser])
  @@index([status])
  @@map("disputes")
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  senderId    String
  senderRole  String
  message     String
  attachments String?
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_messages")
}

model DisputeTimeline {
  id              String   @id @default(cuid())
  disputeId       String
  action          String
  description     String
  performedBy     String
  performedByRole String
  createdAt       DateTime @default(now())
  dispute         Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_timeline")
}

model Review {
  id            String          @id @default(cuid())
  type          ReviewType
  referenceId   String
  bookingId     String?
  source        ReviewSource    @default("DIRECT")
  travelPhase   TravelPhase?
  authorId      String
  title         String?
  content       String
  rating        Float
  cleanliness   Float?
  location      Float?
  value         Float?
  serviceRating Float?
  amenities     Float?
  communication Float?
  status        ReviewStatus    @default("PUBLISHED")
  isVerified    Boolean         @default(false)
  helpfulCount  Int             @default(0)
  replyCount    Int             @default(0)
  visitDate     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  helpfulVotes  ReviewHelpful[]
  photos        ReviewPhoto[]
  replies       ReviewReply[]
  author        User            @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([referenceId])
  @@index([type])
  @@index([status])
  @@index([isVerified])
  @@index([bookingId])
  @@index([source])
  @@index([travelPhase])
  @@map("reviews")
}

model ReviewPhoto {
  id        String   @id @default(cuid())
  reviewId  String
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_photos")
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  isHelpful Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_helpful")
}

model ReviewReply {
  id         String   @id @default(cuid())
  reviewId   String
  authorId   String
  authorName String
  authorRole String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_replies")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  serviceId String?
  productId String?
  createdAt DateTime @default(now())

  @@unique([userId, serviceId, productId])
  @@index([userId])
  @@index([serviceId])
  @@index([productId])
  @@map("wishlist_items")
}

model ReviewerProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  level         ReviewerLevel @default("NEW_REVIEWER")
  badges        String?
  totalReviews  Int           @default(0)
  totalHelpful  Int           @default(0)
  totalPhotos   Int           @default(0)
  citiesVisited String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([level])
  @@map("reviewer_profiles")
}

enum Role {
  GUEST
  USER
  HOST
  PROVIDER
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum MembershipLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum OAuthProvider {
  GOOGLE
  APPLE
  FACEBOOK
}

enum OTPType {
  LOGIN
  REGISTER
  VERIFY
  RESET_PASSWORD
}

enum VerificationType {
  IDENTITY
  PHONE
  EMAIL
  ADDRESS
  BUSINESS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CompanyType {
  HOTEL
  TOUR_OPERATOR
  TRANSPORT
  RESTAURANT
  SHOP
  TRAVEL_AGENCY
  CAR_RENTAL
  EVENT_ORGANIZER
  OTHER
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum EmployeeRole {
  OWNER
  MANAGER
  STAFF
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum DestinationType {
  CITY
  HISTORICAL_SITE
  NATURAL_LANDMARK
  RELIGIOUS_SITE
  MUSEUM
  BEACH
  MOUNTAIN
  PARK
  MARKET
  OTHER
}

enum ActivityType {
  TOUR
  EXPERIENCE
  WORKSHOP
  ADVENTURE
  CULTURAL
  RELAXATION
  FOOD_TOUR
  PHOTOGRAPHY
  WATER_SPORT
  OTHER
}

enum TourType {
  CITY_TOUR
  DAY_TRIP
  MULTI_DAY
  ADVENTURE
  CULTURAL
  RELIGIOUS
  FOOD_TOUR
  NATURE
  CUSTOM
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
  CANCELLED
}

enum EscrowTransactionType {
  FUND
  RELEASE
  REFUND
  PARTIAL_REFUND
  FEE
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum ReviewType {
  SERVICE
  ACTIVITY
  DESTINATION
  PRODUCT
  COMPANY
}

enum ReviewerLevel {
  NEW_REVIEWER
  ACTIVE_REVIEWER
  EXPERT_REVIEWER
  TRUSTED_REVIEWER
}

enum ReviewSource {
  BOOKING
  COMMUNITY
  MARKETPLACE
  DIRECT
}

enum TravelPhase {
  BEFORE
  DURING
  AFTER
}

